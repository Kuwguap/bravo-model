# ─── Shared across all apps/bots ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Payments (Stripe everywhere)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Email (SendGrid everywhere)
SENDGRID_API_KEY=
SENDGRID_FROM=no-reply@njtemporarytag.com
APP_NAME=NJ Temporary Tag

# OpenAI (lead parsing + field normalization)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Tag site (apps/tag-site) ─────────────────────────────────────────────────
APP_URL=http://localhost:5173
TAG_PRICE=150
INSURANCE_OPT_IN_PRICE=100
RENEWAL_PERIOD_DAYS=28
ADMIN_PASSWORD=
SESSION_SECRET=
# Where paid orders are pushed for dispatch:
DISPATCH_BOT_URL=http://localhost:8080
# Shared secret the tag site sends and the bot verifies on /leads:
DISPATCH_SHARED_SECRET=

# ─── Dispatch bot (apps/dispatch-bot) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Public HTTPS base of the bot (Render URL) for setting the Telegram webhook:
DISPATCH_PUBLIC_URL=
# Seconds before an unclaimed lead is re-broadcast to drivers:
FALLBACK_CLAIM_TIMEOUT_MS=300000
PORT=8080

# ─── Central bot + dashboard (apps/central-bot) ───────────────────────────────
# Reuses ADMIN_PASSWORD, SESSION_SECRET, SUPABASE_*, SENDGRID_*, APP_URL above.
TELEGRAM_CENTRAL_BOT_TOKEN=
# Public HTTPS base (Render URL) for the central bot's Telegram webhook:
CENTRAL_PUBLIC_URL=
# In-process renewal sweep cadence in minutes (0 disables; use Render Cron instead):
RENEWAL_SWEEP_MINUTES=360
