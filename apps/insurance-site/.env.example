# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional server-only duplicate of project URL (works for admin server actions if you prefer not to expose URL as NEXT_PUBLIC_* during setup). Prefer NEXT_PUBLIC for the browser client.
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Server-only: never expose to the browser. Used by admin “Add Client” and /admin user list + edit.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend (policy welcome emails; attach PDF on Telegram integration + admin flows)
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=noreply@your-verified-domain.com

# Telegram bot → POST /api/integrations/telegram (multipart fullName + file PDF).
# Generate a long random string; send as Authorization: Bearer <secret>
# TELEGRAM_INTEGRATION_SECRET=

# Server-to-server "create client" API → POST /api/integrations/clients.
# Send as Authorization: Bearer <secret>, X-Api-Key, or X-Integrations-Api-Key.
# Used by external bots / automations to create accounts the same way the
# admin panel does. See docs/integrations/create-client-api.md.
# INTEGRATIONS_API_KEY=

# OpenAI (server-only). Powers two AI flows:
#   1. Admin: AI extraction of policy number from uploaded PDF or image.
#   2. Purchase success: "Auto-fill with AI" on /purchase/success — pastes
#      and photo uploads (driver license, insurance card, registration) are
#      sent to /api/purchase/parse-info, which calls gpt-4o-mini (vision-
#      capable) and returns the nine intake fields.
# Leave unset to disable both — the rest of the app works without it.
# OPENAI_API_KEY=sk-...
# Optional model overrides — both default to gpt-4o-mini:
# OPENAI_PARSE_MODEL=gpt-4o-mini
# OPENAI_PARSE_VISION_MODEL=gpt-4o-mini

# Demo DB user (optional): run supabase/seed_demo_account.sql in Supabase SQL Editor → demo@example.com / demo123

# barcode-generator-app: where the portal lives so /api/insurance-card{,-nj}/email
# can call the main NJ Coverage app to provision a member account when it
# sends the welcome message. Leave unset to skip account creation.
# TRISTATE_PORTAL_BASE_URL=https://njcoverage.com
# INTEGRATIONS_API_KEY=your-long-random-secret
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM=NJ Coverage <no-reply@njcoverage.com>